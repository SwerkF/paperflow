{
  "description": "Classification du type de document par regex. Le premier type dont au moins une regex matche peut etre retenu comme type probable.",
  "match_strategy": "first_matching_type",
  "document_types": [
    {
      "type": "devis",
      "description": "Documents de devis / quotation",
      "regexes": [
        "(?i)\\bdevis\\b",
        "(?i)r[ée]f[ée]rence\\s+du\\s+devis",
        "(?i)date\\s+de\\s+validit[ée]",
        "(?i)signature\\s+du\\s+client",
        "(?i)bon\\s+pour\\s+accord",
        "(?i)destinataire",
        "(?i)a\\s+l['’ ]attention\\s+de\\s*:?",
        "(?i)code\\s+client\\s*:?",
        "(?i)devis\\s+valable",
        "(?i)r[ée]capitulatif\\s+de\\s+devis"
      ]
    },
    {
      "type": "facture",
      "description": "Documents de facture / invoice",
      "regexes": [
        "(?i)\\bfacture\\b",
        "(?i)num[ée]ro\\s+de\\s+facture",
        "(?i)date\\s+de\\s+facture",
        "(?i)n\\.?\\s*client",
        "(?i)mode\\s+de\\s+pai?ement",
        "(?i)conditions\\s+de\\s+paiement",
        "(?i)total\\s+ht",
        "(?i)total\\s+tva",
        "(?i)total\\s+ttc",
        "(?i)invoice\\s+number"
      ]
    },
    {
      "type": "kbis",
      "description": "Extrait Kbis / registre du commerce",
      "regexes": [
        "(?i)\\bkbis\\b",
        "(?i)greffe\\s+du\\s+tribunal\\s+de\\s+commerce",
        "(?i)identification\\s+de\\s+la\\s+personne\\s+morale",
        "(?i)immatriculation\\s+au\\s+rcs",
        "(?i)d[ée]nomination\\s+ou\\s+raison\\s+sociale",
        "(?i)gestion\\s*,?\\s*direction",
        "(?i)le\\s+greffier",
        "(?i)extrait\\s+k\\s*bis"
      ]
    },
    {
      "type": "rib",
      "description": "Releve d'identite bancaire",
      "regexes": [
        "(?i)relev[ée]\\s+d[’']?identit[ée]\\s+bancaire",
        "(?i)identifiant\\s+national\\s+de\\s+compte\\s+bancaire\\s*[-–]?\\s*rib",
        "(?i)\\brib\\b",
        "(?i)\\biban\\b",
        "(?i)\\bbic(?:/swift)?\\b",
        "(?i)titulaire\\s+du\\s+compte",
        "(?i)code\\s+banque",
        "(?i)code\\s+guichet",
        "(?i)cl[ée]\\s+rib",
        "(?i)bank\\s+identifier\\s+code"
      ]
    },
    {
      "type": "attestation_siret",
      "description": "Attestation d'immatriculation au RNE / SIRET",
      "regexes": [
        "(?i)attestation\\s+d['’]immatriculation\\s+au\\s+registre\\s+national\\s+des\\s+entreprises",
        "(?i)registre\\s+national\\s+des\\s+entreprises",
        "(?i)identit[ée]\\s+de\\s+l['’]entreprise",
        "(?i)siren\\s*\\(\\s*si[èe]ge\\s*\\)",
        "(?i)date\\s+d['’]immatriculation\\s+au\\s+rne",
        "(?i)adresse\\s+du\\s+si[èe]ge",
        "(?i)forme\\s+juridique",
        "(?i)capital\\s+social",
        "(?i)\\bsiret\\b"
      ]
    },
    {
      "type": "attestation_vigilance_urssaf",
      "description": "Attestation de vigilance URSSAF",
      "regexes": [
        "(?i)\\burssaf\\b",
        "(?i)au\\s+service\\s+de\\s+notre\\s+protection\\s+sociale",
        "(?i)article\\s*l?\\.?\\s*243-15",
        "(?i)code\\s+de\\s+s[ée]curit[ée]",
        "(?i)cotisations\\s+et\\s+contributions\\s+sociales",
        "(?i)authenticit[ée]\\s+de\\s+cette\\s+attestation",
        "(?i)le\\s+directeur",
        "(?i)attestation\\s+de\\s+vigilance"
      ]
    }
  ]
}
