{
  "document_type": {
    "description": "Type de document",
    "regex": "(FACTURE|Facture)",
    "example_match": "FACTURE"
  },
  "bloc_vendeur": {
    "description": "Bloc vendeur",
    "regex": "(.+?GmbH)\\s+(.+?)\\s+(\\d{5}\\s+.+?)\\s+Monsieur Jean Dupont",
    "groups": {
      "1": "nom_vendeur",
      "2": "adresse_vendeur",
      "3": "code_postal_ville_vendeur"
    },
    "example_match": [
      "Sevenit GmbH",
      "Hauptstraße 40",
      "77654 Offenburg"
    ]
  },
  "bloc_client": {
    "description": "Bloc client",
    "regex": "(Monsieur Jean Dupont)\\s+(.+?)\\s+(.+?)\\s+(\\d{5}\\s+.+?)\\s+FACTURE",
    "groups": {
      "1": "nom_client",
      "2": "societe_client",
      "3": "adresse_client",
      "4": "code_postal_ville_client"
    },
    "example_match": [
      "Monsieur Jean Dupont",
      "Acheteur SA",
      "Rue du Chateau",
      "34000 MONTPELLIER"
    ]
  },
  "bloc_infos_facture": {
    "description": "Informations de facture",
    "regex": "Num[ée]ro de facture\\s*:\\s*(\\d+)\\s+Date de facture\\s*:\\s*([0-9]{2}/[0-9]{2}/[0-9]{4})\\s+N.? client\\s*:\\s*(\\d+)",
    "groups": {
      "1": "numero_facture",
      "2": "date_facture",
      "3": "numero_client"
    },
    "example_match": [
      "1001",
      "02/08/2018",
      "321"
    ]
  },
  "bloc_lignes_facture": {
    "description": "Contenu des lignes de facture",
    "regex": "(Main[- ]d.?oeuvre\\s+\\d+\\s+\\S+\\s+[0-9.,]+€\\s+[0-9.,]+€\\s+\\d+%\\s+Tracteur\\s+\\d+\\s+\\S+\\s+[0-9.,]+€\\s+[0-9.,]+€\\s+\\d+%\\s+Bois de chauffage\\s+\\d+\\s+\\S+\\s+[0-9.,]+€\\s+[0-9.,]+€\\s+\\d+%)",
    "groups": {
      "1": "lignes"
    },
    "example_match": [
      "Main-d’oeuvre 30 h. 40,00€ 1200,00€ 20% Tracteur 1 pce. 1800,00€ 1800,00€ 20% Bois de chauffage 10 stére 80,00€ 800,00€ 10%"
    ]
  },
  "bloc_totaux_tva": {
    "description": "Bloc TVA et totaux",
    "regex": "Total HT\\s+Total TVA\\s+Total HT\\s+([0-9 ]+[.,][0-9]{2}\\s*€?)\\s+TVA\\s*20\\s*%?\\s+([0-9 ]+[.,][0-9]{2}\\s*€?)\\s+[0-9 ]+[.,][0-9]{2}\\s*€?\\s+TVA\\s*20\\s*%\\s+([0-9 ]+[.,][0-9]{2}\\s*€?)\\s+TVA\\s*10\\s*%\\s+([0-9 ]+[.,][0-9]{2}\\s*€?)\\s+[0-9 ]+[.,][0-9]{2}\\s*€?\\s+TVA\\s*10\\s*%\\s+([0-9 ]+[.,][0-9]{2}\\s*€?)\\s+Total TTC\\s*[|]?\\s*([0-9 .]+[.,][0-9]{2}€?)",
    "groups": {
      "1": "total_ht",
      "2": "montant_tva20_tableau_gauche",
      "3": "montant_tva20_tableau_droite",
      "4": "montant_tva10_tableau_gauche",
      "5": "montant_tva10_tableau_droite",
      "6": "total_ttc"
    },
    "example_match": [
      "3 800,00 €",
      "600,00 €",
      "600,00 €",
      "80,00 €",
      "80,00 €",
      "4 480,00 €"
    ]
  },
  "bloc_conditions_paiement": {
    "description": "Conditions et mode de paiement",
    "regex": "Conditions de paiement\\s*:\\s*(.+?)\\s+Mode de paiement\\s*:\\s*(.+?)\\s+Nous vous remercions",
    "groups": {
      "1": "conditions_paiement",
      "2": "mode_paiement"
    },
    "example_match": [
      "30 % à la commande, paiement à réception de facture",
      "par virement ou chèque"
    ]
  },
  "bloc_signature_coordonnees": {
    "description": "Bloc coordonnées bas de page et signataire",
    "regex": "Cordialement\\s+(.+?GmbH)\\s+(.+?)\\s+(.+?)\\s+(\\d{5}\\s+.+?)\\s+(.+?)\\s+T[ée]l\\.?\\s*:?\\s*(.+?)\\s+E-?Mail\\s*:?\\s*(.+?)\\s+Details\\s+IBAN\\s+([A-Z]{2}\\s*[0-9A-Z ]{10,34})\\s+BIC\\s+(.+?)\\s+N.? Siret\\s+(.+?)\\s+Code APE\\s+(.+?)\\s+N.? TVA Intracom\\.?\\s+(.+?)\\s+Directeur:?\\s+(.+)$",
    "groups": {
      "1": "nom_societe",
      "2": "adresse",
      "3": "contact_nom",
      "4": "code_postal_ville",
      "5": "pays",
      "6": "telephone",
      "7": "email",
      "8": "iban",
      "9": "bic",
      "10": "siret",
      "11": "code_ape",
      "12": "tva_intracom",
      "13": "directeur"
    },
    "example_match": [
      "Sevenit GmbH",
      "Hauptstraße 40",
      "Max Mustermann",
      "77654 Offenburg",
      "Allemagne",
      "(+49) 7821 - 549370 - 0",
      "info@sevenit.de",
      "DE 85 12345678 0123456789",
      "PBNKDEFF",
      "380 000 000 000XX",
      "0815 C",
      "DE 84 380 000 000",
      "Max Mustermann"
    ]
  },
  "blocs_unitaires_utiles": {
    "date": {
      "description": "Date",
      "regex": "([0-9]{2}/[0-9]{2}/[0-9]{4})",
      "example_match": "02/08/2018"
    },
    "montant": {
      "description": "Montant",
      "regex": "([0-9 ]+[.,][0-9]{2}\\s*€?)",
      "example_match": "3 800,00 €"
    },
    "email": {
      "description": "Email",
      "regex": "([A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,})",
      "example_match": "info@sevenit.de"
    },
    "iban": {
      "description": "IBAN",
      "regex": "([A-Z]{2}\\s*[0-9A-Z ]{10,34})",
      "example_match": "DE 85 12345678 0123456789"
    }
  }
}
