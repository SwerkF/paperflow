{
  "document_type": {
    "description": "Type de document",
    "regex": "(Devis|Facture|Avoir)",
    "example_match": "Devis"
  },
  "bloc_vendeur": {
    "description": "Bloc vendeur : titre + nom entreprise + adresse + ville",
    "regex": "Vendeur\\s+(.+?)\\s+(\\d{1,4},\\s+.+?)\\s+(\\d{5}\\s+.+?)\\s+Client",
    "groups": {
      "1": "nom_entreprise",
      "2": "adresse",
      "3": "code_postal_ville"
    },
    "example_match": [
      "Mon Entreprise",
      "22, Avenue Voltaire",
      "13000 Marseille"
    ]
  },
  "bloc_client": {
    "description": "Bloc client : nom + adresse + ville",
    "regex": "Client\\s+(.+?)\\s+(\\d{1,4},\\s+.+?)\\s+(\\d{5}\\s+.+?)\\s+Date\\s*:",
    "groups": {
      "1": "nom_client",
      "2": "adresse_client",
      "3": "code_postal_ville_client"
    },
    "example_match": [
      "Michel Acheteur",
      "31, rue de la ForĂŞt",
