{
  "document_type": {
    "description": "Type de document",
    "regex": "(FACTURE|Facture|Avoir)"
  },
  "bloc_vendeur": {
    "description": "Bloc vendeur",
    "regex": "heuristic_vendor_segment"
  },
  "bloc_client": {
    "description": "Bloc client",
    "regex": "heuristic_client_segment"
  },
  "bloc_infos_facture": {
    "description": "Informations de facture",
    "regex": "(?:Facture N°|Num[ée]ro de facture|Facture)\\s*:?\\s*([A-Z0-9-]+)[\\s\\S]{0,60}?(?:Date|Le)\\s*:?\\s*([0-9]{2}/[0-9]{2}/[0-9]{4})"
  },
  "bloc_lignes_facture": {
    "description": "Contenu des lignes de facture",
    "regex": "heuristic_lines_between_description_and_total_ht"
  },
  "bloc_totaux_tva": {
    "description": "Bloc TVA et totaux",
    "regex": "(Total HT[\\s\\S]+?Total TTC[\\s\\S]{0,30}?€?)"
  },
  "bloc_conditions_paiement": {
    "description": "Conditions et mode de paiement",
    "regex": "(?:Conditions de paiement|Paiement|Échéance)\\s*:\\s*(.+?)\\s+(?:Mode de pai?ement|Règlement par)\\s*:\\s*(.+?)(?:$|\\n|Nous vous remercions|Merci)"
  },
  "bloc_signature_coordonnees": {
    "description": "Bloc coordonnées bas de page et signataire",
    "regex": "heuristic_signature_from_rec_texts"
  }
}